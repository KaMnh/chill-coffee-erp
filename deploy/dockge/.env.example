# ============================================================================
# Chill Coffee ERP v4 — Production .env (Dockge stack)
# ============================================================================
# 1. Copy this file to `.env` in the same folder (Dockge will edit it via UI).
# 2. Generate Supabase secrets ONCE on a dev machine:
#       bash supabase/utils/generate-keys.sh
#    Paste the output into Section 3 below.
# 3. Set Section 1 (App) values to match your reverse-proxy domains.
# 4. NEVER commit this file. NEVER share JWT_SECRET or SERVICE_ROLE_KEY.
# ============================================================================


# ─────────────────────────────────────────────
# SECTION 0 — Host port mapping + container naming
# ─────────────────────────────────────────────
# Change these if the defaults conflict with other services on the mini-PC.
# These are the host (outside Docker) ports the reverse proxy will hit.

APP_PORT=3009
KONG_HTTP_PORT=8000
# KONG_HTTPS_PORT=8443     # Uncomment only if proxying Supabase without upstream TLS

# Prefix prepended to every container name in this stack. Leave EMPTY to keep
# default names (chill-app, supabase-db, supabase-kong, ...). Set a value like
# `quan2-` (note trailing hyphen) if you run another Supabase stack on the same
# Docker daemon and need to avoid container name collisions. The prefix also
# applies to realtime's tenant ID (healthcheck path uses ${STACK_NAMESPACE}realtime-dev).
STACK_NAMESPACE=


# ─────────────────────────────────────────────
# SECTION 1 — App (Next.js)
# ─────────────────────────────────────────────
# Public URLs are what the BROWSER sees, after your reverse proxy.
# They are independent of the host ports above.

# REQUIRED — public URL of your reverse-proxied Kong (Supabase API). Example: https://supabase.example.com
NEXT_PUBLIC_SUPABASE_URL=
# REQUIRED — public URL of your reverse-proxied Next.js app. Example: https://app.example.com
NEXT_PUBLIC_APP_URL=

# Server-only — overridden by docker-compose to point at the internal Kong service.
SUPABASE_INTERNAL_URL=http://kong:8000

# KiotViet POS ingest. Leave INGEST_CLIENT_SECRET empty on first deploy — set it
# AFTER the integration_clients table is seeded. The bcrypt hash lives in the DB;
# this var holds the plaintext used at request time. Rotate with `openssl rand -hex 32`.
INGEST_CLIENT_ID=chill-erp
INGEST_CLIENT_SECRET=

# Optional — cron polling secret. Generate with `openssl rand -hex 32`. Empty = cron disabled.
CRON_SECRET=

# Admin Postgres URL for the in-app backup/restore UI is NOT set here — it's
# constructed inside compose.yaml's `app.environment:` block where Compose can
# safely interpolate POSTGRES_PASSWORD from Section 3 below.
# (Defining it here would fail because Compose .env parsing is strictly top-down
# and POSTGRES_PASSWORD is declared further down.)


# ─────────────────────────────────────────────
# SECTION 2 — Supabase API URLs
# ─────────────────────────────────────────────
# These are used internally by Supabase services. Mostly point at the same
# public URL the browser uses.

API_EXTERNAL_URL=${NEXT_PUBLIC_SUPABASE_URL}
SUPABASE_PUBLIC_URL=${NEXT_PUBLIC_SUPABASE_URL}
SITE_URL=${NEXT_PUBLIC_APP_URL}
ADDITIONAL_REDIRECT_URLS=

# SUPABASE_ANON_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
# are constructed inside compose.yaml's app.environment: block from ANON_KEY and
# SERVICE_ROLE_KEY (Section 3 below). Defining them here would fail because
# Compose .env parsing is strictly top-down.


# ─────────────────────────────────────────────
# SECTION 3 — Supabase secrets (GENERATE, then paste)
# ─────────────────────────────────────────────
# Generate via:    bash supabase/utils/generate-keys.sh
# Paste the printed values below.

POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
SECRET_KEY_BASE=
VAULT_ENC_KEY=

# Asymmetric keys (optional — leave empty for legacy HS256 only)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=

# Supabase Studio dashboard basic-auth
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=


# ─────────────────────────────────────────────
# SECTION 4 — Supabase Postgres
# ─────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Init-guard for production data loss prevention. Leave 0 for the first deploy
# (so Postgres can bootstrap a fresh data dir). After deploy succeeds and you
# can log in, switch to 1. From then on, if Postgres starts and finds an empty
# data dir (volume wiped, prune, version mismatch), the init-guard script
# refuses to fresh-init and the container exits with FATAL — so you notice
# BEFORE customer data is gone instead of after. Recovery runbook is in
# README.md → "Recovery runbook — empty PGDATA detected".
CHILL_REQUIRE_EXISTING_DATA=0

# Automatic backup (the chill-backup-cron sidecar).
# BACKUP_TIME_UTC is HH:MM in UTC. Default 02:00 UTC = 09:00 ICT.
# BACKUP_RETENTION_DAYS prunes .dump and db-config-*.tgz older than N days.
# RUN_INITIAL_BACKUP=1 also runs a backup immediately when the sidecar starts
# (so you always have at least one snapshot, no need to wait for tomorrow).
BACKUP_TIME_UTC=02:00
BACKUP_RETENTION_DAYS=14
RUN_INITIAL_BACKUP=1


# ─────────────────────────────────────────────
# SECTION 5 — Supabase Auth (GoTrue)
# ─────────────────────────────────────────────
# DISABLE_SIGNUP=true blocks self-signup at the GoTrue level (the app uses its
# own signup_requests admin-approval flow instead). Keep ENABLE_EMAIL_SIGNUP=true
# because GoTrue treats that flag as "is email provider enabled" — setting it
# false blocks email LOGIN too (returns 422 email_provider_disabled), which
# means the seeded owner cannot sign in.
DISABLE_SIGNUP=true
JWT_EXPIRY=3600

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME="Chill Coffee ERP"

MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify


# ─────────────────────────────────────────────
# SECTION 6 — Supabase Studio
# ─────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION="Chill Coffee"
STUDIO_DEFAULT_PROJECT="Chill Coffee ERP"
OPENAI_API_KEY=
PG_META_CRYPTO_KEY=
PGRST_DB_SCHEMAS=public,storage,graphql_public,analytics
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public


# ─────────────────────────────────────────────
# SECTION 7 — Supabase Logflare / Analytics
# ─────────────────────────────────────────────
LOGFLARE_PUBLIC_ACCESS_TOKEN=
LOGFLARE_PRIVATE_ACCESS_TOKEN=


# ─────────────────────────────────────────────
# SECTION 8 — Supabase Functions (optional)
# ─────────────────────────────────────────────
FUNCTIONS_VERIFY_JWT=false


# ─────────────────────────────────────────────
# SECTION 9 — Supabase Supavisor connection pooler
# ─────────────────────────────────────────────
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=chill-coffee-erp
POOLER_DB_POOL_SIZE=5
POOLER_POOL_MODE=transaction


# ─────────────────────────────────────────────
# SECTION 10 — Supabase Storage + imgproxy + Vector
# ─────────────────────────────────────────────
# Required by services declared in supabase/docker-compose.yml. Defaults are
# safe for a single-node self-host with file-backed (not S3) storage.

DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GLOBAL_S3_BUCKET=stub
REGION=local
STORAGE_TENANT_ID=chill-coffee-erp
IMGPROXY_AUTO_WEBP=true

# S3-protocol endpoint of the storage service (Supabase exposes its OWN S3 API,
# regardless of whether the backing store is filesystem or real S3). Generate
# fresh with `openssl rand -hex 32`. Used by clients that want S3-compatible access.
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

# Asymmetric API keys (ES256). Optional — leave empty for legacy HS256 only.
# Kong references these with `:-` defaults so empty is safe.
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=


# ─────────────────────────────────────────────
# SECTION 11 — App image tag (Dockge pulls this)
# ─────────────────────────────────────────────
# Set to a specific release like `v4.0.1` for reproducible deploys.
# Use `latest` only for rolling deploys (less safe).

CHILL_ERP_IMAGE=ghcr.io/REPLACE_WITH_GITHUB_OWNER/chill-coffee-erp:v4.0.0


# ─────────────────────────────────────────────
# SECTION 12 — First-deploy owner account (auto-seed)
# ─────────────────────────────────────────────
# The migrator container creates this owner account ON FIRST DEPLOY if both
# values are set AND no active owner exists yet. After the first successful
# seed, you can clear these values (the migrator will skip on re-runs because
# an owner already exists). Password must be >= 8 characters.
#
# Leave BOTH empty to skip auto-seed entirely — you'll create the first owner
# manually via Supabase Studio (https://supabase.example.com/project/default).

OWNER_EMAIL=
OWNER_PASSWORD=


# ─────────────────────────────────────────────
# SECTION 13 — Employee self-check-in security
# ─────────────────────────────────────────────
# The /api/checkin route accepts requests only when they arrive through the
# designated reverse proxy. The proxy must inject the x-checkin-proxy-secret
# header on every request; the app rejects check-in attempts without it (503).
#
# The app port is bound to 127.0.0.1 in compose.yaml — direct off-host access
# is blocked at the kernel level. These vars harden the application layer.

# REQUIRED in production — generate with: openssl rand -hex 32
# Leave empty to disable check-in entirely (503 on every attempt).
CHECKIN_PROXY_SECRET=

# Number of trusted reverse-proxy hops between the internet and this app.
# 1 = one proxy (nginx/caddy/etc. on this host). Ignored when
# CHECKIN_TRUSTED_IP_HEADER is set (the header is then the ONLY source).
CHECKIN_TRUSTED_PROXY_COUNT=1

# Platform real-IP header — the header your trusted edge sets to the REAL visitor
# IP. STRONGLY RECOMMENDED when behind Cloudflare:
#
#     CHECKIN_TRUSTED_IP_HEADER=cf-connecting-ip
#
# Why: behind Cloudflare the right-most x-forwarded-for hop is a Cloudflare EDGE
# IP that ROTATES per request, so the anchor IP and the employee's IP never match
# and every check-in fails. cf-connecting-ip is the real ISP IP and is stable.
#
# Anti-spoof: when this is set it is the ONLY trusted source — a request missing a
# valid value here is REJECTED (fail-closed), never silently downgraded to the
# spoofable x-forwarded-for chain. Cloudflare overwrites any client-supplied
# cf-connecting-ip, and CHECKIN_PROXY_SECRET + the 127.0.0.1 port binding stop
# direct-to-origin bypass. For full lockdown, also restrict the origin firewall to
# Cloudflare IP ranges (or enable Cloudflare Authenticated Origin Pulls).
#
# Leave empty ONLY if you are NOT behind a platform proxy (plain nginx → app),
# in which case x-forwarded-for + the hop count above is used.
CHECKIN_TRUSTED_IP_HEADER=

# Rate-limiter for /api/checkin: max requests per window, per process.
# Note: the rate-limiter is in-process (not shared across restarts/replicas).
CHECKIN_RATE_MAX=10
CHECKIN_RATE_WINDOW_MS=60000
