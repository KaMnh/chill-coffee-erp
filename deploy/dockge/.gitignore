# Runtime data — never commit
.env
.env.local

# Postgres data (Supabase image manages contents — UID 70)
volumes/db/data/

# Storage uploads
volumes/storage/*
!volumes/storage/.gitkeep

# pg_dump backups produced by the in-app Settings UI
volumes/backups/*
!volumes/backups/.gitkeep

# Studio snippets / Edge functions code (runtime-managed)
volumes/snippets/*
!volumes/snippets/.gitkeep
volumes/functions/*
!volumes/functions/.gitkeep

# Container logs
volumes/logs/*
!volumes/logs/.gitkeep

# Kong temp config file generated by kong-entrypoint.sh
volumes/api/kong-temp.yml

# OS noise
.DS_Store
Thumbs.db
