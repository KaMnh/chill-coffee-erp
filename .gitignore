node_modules/
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# Env — KHÔNG commit secrets
.env
.env.local
supabase/.env

# Supabase runtime data (tạo lúc chạy)
supabase/volumes/db/data/
supabase/volumes/storage/
supabase/volumes/logs/
# pooler dir contains pooler.exs config (must be tracked — Docker bind-mounts
# nó vào container; nếu thiếu, Docker auto-tạo empty dir → pooler crash).
# Chỉ ignore runtime data dưới đó nếu có.
supabase/volumes/pooler/*
!supabase/volumes/pooler/pooler.exs

.DS_Store

# Production data dumps (Phase 3A verification artifacts)
# Contains real customer / financial data — never commit.
mirrors/

# Vitest coverage output (not generated yet — Phase 6 will turn this on)
coverage/

# Migration tooling (one-time v2 → v4) — chứa SQL dump + reports, KHÔNG commit
/migration/
/backup/

# Claude Code harness config (worktree-local launch.json, etc.)
.claude/

# Superpowers brainstorming visual companion (mockups, state)
.superpowers/
