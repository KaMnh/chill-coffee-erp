# Runtime data — never commit
.env
.env.local

# Postgres data — now lives in the EXTERNAL named volume `chill-erp-db-data`
# (see compose.yaml + README). If volumes/db/data/ exists on disk, the bind-
# mount → named-volume migration has NOT been run yet. See README section
# "Migrating an existing installation".
volumes/db/data/

# Storage uploads
volumes/storage/*
!volumes/storage/.gitkeep

# pg_dump backups produced by the in-app Settings UI
volumes/backups/*
!volumes/backups/.gitkeep

# Studio snippets (runtime-managed)
volumes/snippets/*
!volumes/snippets/.gitkeep

# Edge functions code (synced from upstream supabase/volumes/functions/ via sync-volumes.sh)
volumes/functions/*
!volumes/functions/.gitkeep
!volumes/functions/main/
!volumes/functions/main/index.ts
!volumes/functions/hello/
!volumes/functions/hello/index.ts

# Container logs (runtime-managed) — but vector.yml is a committed stub config
volumes/logs/*
!volumes/logs/.gitkeep
!volumes/logs/vector.yml

# Kong temp config file generated by kong-entrypoint.sh
volumes/api/kong-temp.yml

# OS noise
.DS_Store
Thumbs.db
